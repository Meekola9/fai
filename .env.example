# FAI — optional cloud storage (Supabase).
# Copy this file to .env.local (local dev) or set these as Environment
# Variables in Vercel, then redeploy. Values come from your Supabase project:
# Dashboard → Project Settings → API.
#
# Without these, FAI works fully — it just stores data in each browser
# (no cross-device sync, no shared team access).

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: a shared code so your whole staff sees the same data.
# Everyone using the same code shares one dataset. Defaults to "default".
VITE_FAI_TEAM_CODE=my-team-2026
